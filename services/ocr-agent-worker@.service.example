[Unit]
Description=OCR Platform Agent Worker %i
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ocr-agent
Group=ocr-agent
SupplementaryGroups=ocr-runtime
EnvironmentFile=/etc/ocr-agent/%i.env
WorkingDirectory=/opt/ocr-platform/ocrparser
ExecStart=/opt/ocr-platform/ocrparser/scripts/ocr_agent_worker.sh run /etc/ocr-agent/%i.env
ExecStop=/opt/ocr-platform/ocrparser/scripts/ocr_agent_worker.sh stop /etc/ocr-agent/%i.env
ExecReload=/opt/ocr-platform/ocrparser/scripts/ocr_agent_worker.sh restart /etc/ocr-agent/%i.env
Restart=always
RestartSec=10
TimeoutStartSec=30
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
