ARG BASE_IMAGE=nvcr.io/nvidia/vllm@sha256:13e327dad79e6e417f6687fec2ba76b0386d597082ec0ee003c1e964ec6ad0e7
FROM ${BASE_IMAGE}

ARG SGLANG_REVISION=0fe2dbd42caeb627bd8aca162dab7763d292fda9
ARG SGLANG_SOURCE_SHA256=c2bcbd305cfd9f0260a8ede833b1120bb804562369b77f4798855616857aeb16
ARG SGLANG_KERNEL_VERSION=0.4.4
ARG TRANSFORMERS_VERSION=5.5.4
ARG FLASHINFER_VERSION=0.6.7.post3
ARG PADDLE_MODEL_REVISION=d911116c363676c602c4786ad0b9667b1aee055f
ARG PIP_INDEX_URL=https://pypi.org/simple

LABEL org.opencontainers.image.title="OcrParser PaddleOCR-VL ARM64 runtime" \
      org.opencontainers.image.source="https://github.com/albaNnaksqr/OcrParser" \
      org.opencontainers.image.base.digest="sha256:13e327dad79e6e417f6687fec2ba76b0386d597082ec0ee003c1e964ec6ad0e7" \
      org.opencontainers.image.revision="${SGLANG_REVISION}" \
      io.ocrparser.model.revision="${PADDLE_MODEL_REVISION}"

RUN test "$(uname -m)" = "aarch64"

COPY deploy/engines/paddleocr-vl/sglang-source.tar.gz /tmp/sglang.tar.gz

RUN echo "${SGLANG_SOURCE_SHA256}  /tmp/sglang.tar.gz" | sha256sum --check \
    && mkdir -p /opt/sglang \
    && tar -xzf /tmp/sglang.tar.gz --strip-components=1 -C /opt/sglang \
    && rm /tmp/sglang.tar.gz

RUN python -m pip uninstall --yes vllm sglang-kernel \
    && python -m pip install --no-cache-dir --upgrade \
      --index-url "${PIP_INDEX_URL}" \
      "anthropic==0.96.0" \
      "blobfile==3.0.0" \
      "compressed-tensors==0.15.0.1" \
      "datasets==4.8.4" \
      "easydict==1.13" \
      "huggingface-hub==1.11.0" \
      "llguidance==0.7.30" \
      "modelscope==1.36.1" \
      "msgspec==0.21.1" \
      "openai==2.6.1" \
      "orjson==3.11.8" \
      "outlines==0.1.11" \
      "scikit-build-core==0.11.6" \
      "timm==1.0.16" \
      "transformers==${TRANSFORMERS_VERSION}" \
      "flashinfer-python==${FLASHINFER_VERSION}"

RUN CMAKE_BUILD_PARALLEL_LEVEL=4 \
    python -m pip install --no-build-isolation --no-cache-dir \
      /opt/sglang/sgl-kernel

RUN python -m pip install --no-cache-dir \
      --index-url "${PIP_INDEX_URL}" \
      "ipython==9.12.0"

ENV PYTHONPATH=/opt/sglang/python \
    FLASHINFER_DISABLE_VERSION_CHECK=1

RUN python - <<'PY'
import importlib.metadata as metadata
import platform
from pathlib import Path
import sglang
import sgl_kernel
import torch
import transformers

expected = {
    "compressed-tensors": "0.15.0.1",
    "llguidance": "0.7.30",
    "orjson": "3.11.8",
    "sglang-kernel": "0.4.4",
    "flashinfer-python": "0.6.7.post3",
    "transformers": "5.5.4",
}
assert platform.machine() == "aarch64", platform.machine()
for package, version in expected.items():
    assert metadata.version(package) == version, (package, metadata.version(package))
assert Path(sglang.__file__).resolve().is_relative_to(Path("/opt/sglang")), sglang.__file__
kernel_root = Path(sgl_kernel.__file__).resolve().parent
common_ops = sorted(kernel_root.glob("sm100/common_ops*"))
assert common_ops, f"missing source-built SM100/SM121 extension under {kernel_root}"
assert torch.__version__ == "2.11.0a0+a6c236b9fd.nv26.03.46836102", torch.__version__
assert transformers.__version__ == "5.5.4", transformers.__version__
PY

EXPOSE 30001
HEALTHCHECK --interval=15s --timeout=5s --start-period=180s --retries=12 \
    CMD curl -fsS http://127.0.0.1:30001/health || exit 1

ENTRYPOINT ["python", "-m", "sglang.launch_server"]
