{
  "cli_defaults": {
    "output_dir": "./output",
    "prompt": "prompt_layout_all_en",
    "ip": "localhost",
    "port": 8000,
    "model_name": "model",
    "engine": "dotsocr",
    "page_concurrency": 24,
    "file_concurrency": 1,
    "max_retries": 8,
    "retry_delay": 2.0,
    "skip_blank_pages": false,
    "disable_resume": false,
    "flatten_output": false
  },
  "exit_codes": {
    "success": 0,
    "empty_or_missing_input": 1,
    "argument_error": 2
  },
  "manifest_jsonl": "{\"input_path\":\"/public/input.pdf\",\"relative_path\":\"nested/input.pdf\",\"size_bytes\":123,\"mtime_ns\":456}",
  "engine_page_result": {
    "page_no": 1,
    "original_page_num": 1,
    "status": "success",
    "native_artifacts": [],
    "cells": [{"category": "Text", "text": "hello"}],
    "original_cells": null,
    "page_json_path": "page_1.json",
    "page_layout_path": null
  },
  "openapi_paths": {
    "/api/agents/{server_id}/next-job": ["post"],
    "/api/jobs": ["get", "post"],
    "/api/jobs/page": ["get"],
    "/api/jobs/preflight": ["post"],
    "/api/jobs/summary": ["get"],
    "/api/jobs/summary/page": ["get"],
    "/api/jobs/{job_id}": ["delete", "get"],
    "/api/jobs/{job_id}/archive": ["post"],
    "/api/jobs/{job_id}/events": ["post"],
    "/api/jobs/{job_id}/logs": ["post"],
    "/api/jobs/{job_id}/logs/page": ["get"],
    "/api/jobs/{job_id}/manifest": ["post"],
    "/api/jobs/{job_id}/manifest/freeze-report": ["get"],
    "/api/jobs/{job_id}/manifest/integrity": ["get"],
    "/api/jobs/{job_id}/manifest/integrity/worker-request": ["post"],
    "/api/jobs/{job_id}/recent-errors/page": ["get"],
    "/api/jobs/{job_id}/recent-files": ["get"],
    "/api/jobs/{job_id}/request-stop": ["post"],
    "/api/jobs/{job_id}/shards": ["get"],
    "/api/jobs/{job_id}/shards/claim": ["post"],
    "/api/jobs/{job_id}/shards/{shard_id}/attempts": ["get"],
    "/api/jobs/{job_id}/shards/{shard_id}/attempts/page": ["get"],
    "/api/jobs/{job_id}/summary": ["get"],
    "/api/manifest-integrity/claim": ["post"],
    "/api/manifest-integrity/{manifest_id}/complete": ["post"],
    "/api/model-profiles": ["get"],
