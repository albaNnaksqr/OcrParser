# Copy this file to /etc/ocr-agent/worker.env or a host-local path.
# Keep one unique server id per worker process.

OCR_AGENT_SERVER_ID=ocr-worker-01
OCR_CONTROL_URL=http://ocr-control.internal:8080
# Must match OCR_PLATFORM_API_TOKEN on the control host when API auth is enabled.
OCR_CONTROL_API_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN

# Repository and runtime.
OCR_REPO_DIR=/opt/ocr-platform/ocrparser
OCR_AGENT_WORK_DIR=/var/lib/ocr-agent/worker-01
OCR_AGENT_PYTHON=/opt/ocr-platform/ocrparser/.venv/bin/python

# Colon-separated shared filesystem roots the worker can access. Each root is
# reported in heartbeat and may contain job input/output paths plus the
# platform-owned manifest_root subtree.
OCR_AGENT_SHARED_ROOTS=/shared/ocr-data

# Optional tuning.
OCR_AGENT_POLL_INTERVAL=2
OCR_AGENT_HEARTBEAT_INTERVAL=5
OCR_AGENT_CONTROL_RETRY_INITIAL=1
OCR_AGENT_CONTROL_RETRY_MAX=30
OCR_AGENT_EVENT_SPOOL_DIR=/var/lib/ocr-agent/worker-01/event-spool
OCR_AGENT_EVENT_SPOOL_MAX_MB=1024
OCR_AGENT_TERMINATION_TIMEOUT=10
OCR_AGENT_STOP_POLL_INTERVAL=1
OCR_MANIFEST_SCAN_PROGRESS_INTERVAL_FILES=10000
# Resource guard pauses new shard claims and writes execution-control.json for
# running parser children so new API calls pause until pressure clears.
OCR_AGENT_RESOURCE_GUARD_MEMORY_PERCENT=90
OCR_AGENT_RESOURCE_GUARD_MIN_AVAILABLE_MEMORY_GB=4
OCR_AGENT_RESOURCE_GUARD_DISK_PERCENT=95
OCR_AGENT_RESOURCE_GUARD_MIN_FREE_DISK_GB=10
OCR_AGENT_RUNNER=tmux
OCR_AGENT_LOG_DIR=/var/log/ocr-agent/worker-01
OCR_AGENT_TMUX_SESSION=ocr-agent-worker-01

# Optional deploy metadata for status/doctor output.
OCR_AGENT_GIT_REF=v2026.05.28
OCR_AGENT_SCRIPT_VERSION=ocr-agent-worker-v1

# Control-host recovery timeout env vars, shown here for reference. Set these on
# the control API process, not on worker-only hosts.
# OCR_JOB_STALE_AFTER_SECONDS=120
# OCR_SERVER_STALE_AFTER_SECONDS=120
# OCR_SHARD_LEASE_SECONDS=300
