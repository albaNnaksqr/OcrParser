# Copy this file to /etc/ocr-platform/control.env on the control host.
# Use PostgreSQL for production. SQLite is only for local development or smoke tests.

OCR_PLATFORM_DATABASE_URL=postgresql+psycopg://ocr_platform:CHANGE_ME@postgres.internal:5432/ocr_platform
# Refuse non-PostgreSQL database URLs in production.
OCR_PLATFORM_REQUIRE_POSTGRES=1
# Refuse to start if PostgreSQL SQL migrations are not current.
OCR_PLATFORM_REQUIRE_CURRENT_MIGRATIONS=1
OCR_PLATFORM_HOST=127.0.0.1
OCR_PLATFORM_PORT=8080
# Set a high-entropy shared token in production. API requests must send either
# Authorization: Bearer <token>, X-API-Key: <token>, or X-OCR-Platform-Token: <token>.
OCR_PLATFORM_API_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN
# Refuse to start without OCR_PLATFORM_API_TOKEN in production.
OCR_PLATFORM_REQUIRE_API_TOKEN=1
# Saved model profile or per-job API keys are refused by default; use api_key_env_var.
# Set this only for an explicitly accepted legacy deployment.
OCR_PLATFORM_ALLOW_SAVED_MODEL_PROFILE_KEYS=0

# Remote SSH-based worker lifecycle endpoints are disabled by default.
OCR_PLATFORM_ENABLE_REMOTE_ADMIN=0

OCR_JOB_STALE_AFTER_SECONDS=120
OCR_SERVER_STALE_AFTER_SECONDS=120
OCR_SHARD_LEASE_SECONDS=300
# Distributed scan-unit claim reads a bounded batch with PostgreSQL
# FOR UPDATE SKIP LOCKED before worker/path eligibility checks.
OCR_SCAN_UNIT_CLAIM_BATCH_SIZE=100

# Retain only recent per-file and raw event details in the control database.
# Set to 0 in very large production runs to disable detail rows. Job summaries
# still use aggregate counters and shard counters.
# The control service also keeps bounded recent failed-file and job-level error
# samples in job_counters so failure triage survives with detail rows disabled.
# Manifest files and shard files stay on the shared filesystem.
OCR_JOB_FILE_DETAIL_LIMIT=10000
OCR_JOB_EVENT_DETAIL_LIMIT=50000
OCR_JOB_LOG_DETAIL_LIMIT=10000
OCR_JOB_FAILED_FILE_SAMPLE_LIMIT=100
OCR_JOB_RECENT_ERROR_SAMPLE_LIMIT=100
